{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "dotnet publish DocuTrack.Api/DocuTrack.Api.csproj -c Release -o out"
  },
  "deploy": {
    "startCommand": "cd out && dotnet DocuTrack.Api.dll",
    "restartPolicyType": "ON_FAILURE"
  }
}
